{
  "name": "@meritview/api",
  "type": "module",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@meritview/llm-abstraction": "workspace:*",
    "@meritview/shared": "workspace:*",
    "express": "4.19.x",
    "cors": "2.8.x",
    "helmet": "7.1.x",
    "express-rate-limit": "7.1.x",
    "rate-limit-redis": "4.2.x",
    "jsonwebtoken": "9.0.x",
    "bcrypt": "5.1.x",
    "zod": "3.22.x",
    "stripe": "14.x",
    "@prisma/client": "5.14.x",
    "redis": "4.6.x",
    "nodemailer": "6.9.x",
    "@aws-sdk/client-s3": "3.x",
    "@aws-sdk/client-ses": "3.x",
    "puppeteer": "21.x",
    "@sentry/node": "7.x",
    "groq-sdk": "1.3.0",
    "@google/generative-ai": "0.21.x"
  },
  "devDependencies": {
    "@types/express": "4.17.x",
    "@types/cors": "2.8.x",
    "@types/jsonwebtoken": "9.0.x",
    "@types/bcrypt": "5.0.x",
    "@types/node": "20.x",
    "@types/nodemailer": "6.4.x",
    "typescript": "5.4.x",
    "tsx": "4.7.x",
    "eslint": "8.57.x",
    "prisma": "5.14.x"
  }
}
