generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email             String    @unique @db.VarChar(255)
  email_verified    Boolean   @default(false) @db.Boolean
  password_hash     String    @db.VarChar(255)
  display_name      String?   @db.VarChar(100)
  account_type      String    @default("standard") @db.VarChar(20)
  created_at        DateTime  @default(now()) @db.Timestamptz
  updated_at        DateTime  @default(now()) @db.Timestamptz
  deleted_at        DateTime? @db.Timestamptz
  last_login_at     DateTime? @db.Timestamptz

  disputesInitiated Dispute[] @relation("DisputeInitiator")
  payments           Payment[]

  @@index([email], map: "idx_users_email_active")
  @@index([account_type], map: "idx_users_role")
  @@map("users")
}

model Dispute {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category                String    @default("contract_interpretation") @db.VarChar(50)
  title                   String    @db.VarChar(200)
  summary                 String?   @db.Text
  estimated_stakes_usd    Decimal?  @db.Decimal(12, 2)
  state                   String    @default("draft") @db.VarChar(40)
  state_changed_at        DateTime  @default(now()) @db.Timestamptz
  pricing_tier            String    @default("standard") @db.VarChar(20)
  price_usd               Decimal   @default(49.00) @db.Decimal(8, 2)
  initiator_user_id       String    @db.Uuid
  created_at              DateTime  @default(now()) @db.Timestamptz
  updated_at              DateTime  @default(now()) @db.Timestamptz
  completed_at            DateTime? @db.Timestamptz
  deleted_at              DateTime? @db.Timestamptz

  initiator               User     @relation("DisputeInitiator", fields: [initiator_user_id], references: [id])
  parties                 Party[]
  opinions                Opinion?

  @@index([initiator_user_id], map: "idx_disputes_initiator")
  @@index([state], map: "idx_disputes_state")
  @@map("disputes")
}

model Party {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dispute_id    String    @db.Uuid
  role          String    @default("initiator") @db.VarChar(20)
  user_id       String?   @db.Uuid
  brief_status  String    @default("not_started") @db.VarChar(20)
  created_at    DateTime  @default(now()) @db.Timestamptz
  updated_at    DateTime  @default(now()) @db.Timestamptz

  dispute       Dispute   @relation(fields: [dispute_id], references: [id], onDelete: Cascade)
  brief         Brief?

  @@unique([dispute_id, role], map: "uq_parties_dispute_role")
  @@index([dispute_id], map: "idx_parties_dispute")
  @@index([user_id], map: "idx_parties_user")
  @@map("parties")
}

model Brief {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  party_id                 String    @unique @db.Uuid
  dispute_id               String    @db.Uuid
  encrypted_content        Bytes
  content_encryption_key_id String    @db.VarChar(64)
  word_count               Int
  supporting_document_ids  String[]  @default([]) @db.VarChar(255)
  status                   String    @default("draft") @db.VarChar(20)
  created_at               DateTime  @default(now()) @db.Timestamptz
  updated_at               DateTime  @default(now()) @db.Timestamptz
  submitted_at             DateTime? @db.Timestamptz
  sealed_at                DateTime? @db.Timestamptz
  seal_hash                String?   @db.VarChar(64)
  retention_expires_at     DateTime? @db.Timestamptz

  party                    Party     @relation(fields: [party_id], references: [id], onDelete: Cascade)

  @@index([dispute_id], map: "idx_briefs_dispute")
  @@index([status], map: "idx_briefs_status")
  @@index([retention_expires_at], map: "idx_briefs_retention")
  @@map("briefs")
}

model EvaluatorOutput {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dispute_id          String    @db.Uuid
  llm_provider        String    @db.VarChar(50)
  model_id            String    @db.VarChar(100)
  prompt_version      String    @db.VarChar(20)
  structured_output   Json      @db.Json
  raw_output          String?   @db.Text
  parse_success       Boolean   @default(false) @db.Boolean
  parse_errors        Json?     @db.Json
  input_tokens        Int       @default(0)
  output_tokens       Int       @default(0)
  cost_usd            Decimal   @default(0) @db.Decimal(8, 4)
  duration_ms         Int       @default(0)
  attempt_number      Int       @default(1)
  created_at          DateTime  @default(now()) @db.Timestamptz

  @@index([dispute_id], map: "idx_eval_outputs_dispute")
  @@map("evaluator_outputs")
}

model Opinion {
  id                        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dispute_id                String    @unique @db.Uuid
  dispute                   Dispute  @relation(fields: [dispute_id], references: [id])
  encrypted_content         Bytes
  content_encryption_key_id String    @db.VarChar(64)
  eval_prompt_version       String    @db.VarChar(20)
  agg_prompt_version        String    @db.VarChar(20)
  evaluator_output_ids      String[]  @db.VarChar(255)
  inter_evaluator_agreement Decimal?  @db.Decimal(4, 3)
  overall_confidence        Decimal?  @db.Decimal(4, 3)
  aggregator_provider       String    @db.VarChar(50)
  aggregator_model_id       String    @db.VarChar(100)
  total_cost_usd            Decimal   @default(0) @db.Decimal(8, 4)
  pdf_storage_key           String?   @db.VarChar(255)
  pdf_generated_at          DateTime? @db.Timestamptz
  created_at                DateTime  @default(now()) @db.Timestamptz
  delivered_at              DateTime? @db.Timestamptz
  retention_expires_at      DateTime? @db.Timestamptz

  @@index([created_at], map: "idx_opinions_created")
  @@index([retention_expires_at], map: "idx_opinions_retention")
  @@map("opinions")
}

model Payment {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dispute_id              String    @db.Uuid
  user_id                 String    @db.Uuid
  user                    User      @relation(fields: [user_id], references: [id])
  amount_usd              Decimal   @db.Decimal(8, 2)
  currency                String    @default("USD") @db.VarChar(3)
  processor               String    @default("stripe") @db.VarChar(20)
  processor_payment_id    String    @unique @db.VarChar(255)
  status                  String    @default("pending") @db.VarChar(20)
  refunded_amount_usd     Decimal?  @default(0) @db.Decimal(8, 2)
  refund_reason           String?   @db.Text
  refunded_at             DateTime? @db.Timestamptz
  idempotency_key         String?   @unique @db.VarChar(64)
  created_at              DateTime  @default(now()) @db.Timestamptz
  updated_at              DateTime  @default(now()) @db.Timestamptz
  completed_at            DateTime? @db.Timestamptz

  @@index([dispute_id], map: "idx_payments_dispute")
  @@index([user_id], map: "idx_payments_user")
  @@map("payments")
}

model AuditEvent {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_type     String    @db.VarChar(50)
  actor_type     String    @db.VarChar(20)
  actor_id       String?   @db.VarChar(40)
  resource_type  String?   @db.VarChar(40)
  resource_id    String?   @db.VarChar(40)
  event_data     Json?     @db.Json
  ip_address     String?   @db.Inet
  user_agent     String?   @db.Text
  request_id     String?   @db.VarChar(40)
  prev_event_id  String?   @db.VarChar(40)
  signature      String    @db.VarChar(64)
  created_at     DateTime  @default(now()) @db.Timestamptz

  @@index([resource_type, resource_id], map: "idx_audit_events_resource")
  @@index([event_type, created_at], map: "idx_audit_events_type_time")
  @@map("audit_events")
}

model EvaluationJob {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dispute_id     String    @db.Uuid
  state          String    @default("pending") @db.VarChar(20)
  prompt_version String    @db.VarChar(20)
  created_at     DateTime  @default(now()) @db.Timestamptz
  updated_at     DateTime  @default(now()) @db.Timestamptz

  @@index([dispute_id], map: "idx_eval_jobs_dispute")
  @@map("evaluation_jobs")
}
